<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/kara_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <ImageView
            android:layout_width="300dp"
            android:layout_height="180dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="30dp"
            android:src="@drawable/kara_logo" />

        <EditText
            android:id="@+id/edittextNewUsername"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Username"
            android:background="@drawable/bg_input_field"
            android:paddingStart="20dp"
            android:layout_marginBottom="16dp"
            style="@style/TextAppearance.Kara.Body"/>

        <EditText
            android:id="@+id/edittextNewPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:paddingStart="20dp"
            android:layout_marginBottom="16dp"
            style="@style/TextAppearance.Kara.Body"/>

        <EditText
            android:id="@+id/edittextConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Confirm Password"
            android:inputType="textPassword"
            android:background="@drawable/bg_input_field"
            android:paddingStart="20dp"
            android:layout_marginBottom="12dp"
            style="@style/TextAppearance.Kara.Body"/>

        <TextView
            android:id="@+id/textviewReturnLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start"
            android:text="I already have an account"
            android:textColor="@color/kara_primary"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground"
            android:padding="8dp"
            android:layout_marginBottom="32dp"
            style="@style/TextAppearance.Kara.Body"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/buttonRegister"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Create Account"
            android:textAllCaps="false"
            android:textColor="@color/text_on_dark"
            android:background="@drawable/bg_button"
            style="@style/TextAppearance.Kara.Body"/>

    </LinearLayout>
</ScrollView>