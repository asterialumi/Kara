<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F8F3E1">

    <TextView
        android:id="@+id/textviewWelcome"
        android:visibility="visible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome!"
        android:textSize="24sp"
        android:textColor="#41431B"
        android:clickable="true"
        android:layout_marginBottom="36dp"
        android:layout_marginTop="40dp"/>

    <TextView
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:text="This is the main home screen, which will be properly implemented in the future. Stay tuned!"
        android:textAlignment="center"/>

    <ImageView
        android:id="@+id/imageviewDummy"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="center"
        android:src="@drawable/kara_icon"
        android:layout_marginTop="50dp"
        android:layout_marginBottom="60dp"/>

    <Button
        android:id="@+id/buttonLogout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Logout"
        android:textColor="@color/white"
        android:backgroundTint="#41431B"/>

</LinearLayout>