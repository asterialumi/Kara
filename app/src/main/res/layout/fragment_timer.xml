<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="32dp"
    android:background="@color/kara_background">

    <!-- Project Selector -->
    <TextView
        style="@style/TextAppearance.Kara.Subheader"
        android:text="Currently Tracking for:"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <Spinner
        android:id="@+id/spinner_project"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_input_field"
        android:paddingStart="12dp" />

    <!-- The Big Stopwatch -->
    <TextView
        android:id="@+id/textview_stopwatch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00:00"
        android:fontFamily="@font/montserrat_bold"
        android:textColor="@color/kara_primary"
        android:textSize="64sp"
        android:layout_marginTop="80dp"
        android:layout_marginBottom="80dp" />

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_start_pause"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:text="START"
            android:textColor="@color/text_on_dark"
            android:background="@drawable/bg_button"
            app:backgroundTint="@null"
            style="@style/TextAppearance.Kara.Header" />

        <Space
            android:layout_width="24dp"
            android:layout_height="wrap_content" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_stop"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="STOP"
            android:textColor="@color/kara_primary"
            android:background="@drawable/bg_input_field"
            app:backgroundTint="@null"
            android:visibility="gone"
            style="@style/TextAppearance.Kara.Body" />

    </LinearLayout>

</LinearLayout>