<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="24dp"
    android:background="@color/kara_background">

    <!-- Project Selector -->
    <Spinner
        android:id="@+id/spinner_project"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_input_field"
        android:paddingStart="16dp"/>

    <!-- Description Input -->
    <EditText
        android:id="@+id/edittext_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="+ Add Description"
        android:background="@null"
        android:gravity="center"
        android:layout_marginTop="16dp"
        style="@style/TextAppearance.Kara.Body" />

    <!-- Tags Input -->
    <MultiAutoCompleteTextView
        android:id="@+id/edittext_tags"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="+ Add Tags (comma separated)"
        android:background="@null"
        android:gravity="center"
        android:layout_marginTop="8dp"
        style="@style/TextAppearance.Kara.Body" />

    <!-- The Big Stopwatch -->
    <TextView
        android:id="@+id/textview_stopwatch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00:00"
        android:fontFamily="@font/montserrat_bold"
        android:textColor="@color/kara_primary"
        android:textSize="72sp"
        android:layout_weight="1"
        android:gravity="center" />

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <!-- STOP BUTTON -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_stop"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="■"
            android:textSize="32sp"
            android:textColor="@color/kara_primary"
            android:background="@drawable/bg_button_circle"
            app:backgroundTint="@color/kara_input_bg"
            android:visibility="gone" />

        <Space
            android:id="@+id/btn_space"
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:visibility="gone"/>

        <!-- START / PAUSE BUTTON -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_start_pause"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:text="▶"
            android:textSize="32sp"
            android:textColor="@color/text_on_dark"
            android:background="@drawable/bg_button_circle"
            app:backgroundTint="@null" />

    </LinearLayout>
</LinearLayout>