<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kara_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- HERO SECTION: TOTAL TIME -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="32dp"
            android:background="@drawable/bg_button"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_total_tracked"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL TIME TRACKED"
                android:textColor="#A0FFFFFF"
                android:textSize="15sp"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/tv_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00h 00m"
                android:textColor="@color/white"
                android:textSize="34sp"
                android:fontFamily="@font/montserrat_bold" />
        </LinearLayout>

        <!-- PROJECTS LIST -->
        <TextView
            style="@style/TextAppearance.Kara.Subheader"
            android:text="Top Projects"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:descendantFocusability="blocksDescendants">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_project_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </RelativeLayout>

        <!-- TAGS LIST -->
        <TextView
            style="@style/TextAppearance.Kara.Subheader"
            android:text="Top Tags"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:descendantFocusability="blocksDescendants">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_tag_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </RelativeLayout>

    </LinearLayout>
</ScrollView>