<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kara_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 1. THE CLOCK -->
        <TextClock
            android:id="@+id/dashboard_clock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:format12Hour="hh:mm a"
            android:fontFamily="@font/montserrat_bold"
            android:textColor="@color/kara_primary"
            android:textSize="48sp" />

        <TextClock
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:format12Hour="EEEE, MMMM dd"
            android:fontFamily="@font/inter_medium"
            android:textColor="@color/kara_accent"
            android:textSize="16sp"
            android:layout_marginBottom="20dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/buttonLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textColor="@color/text_on_dark"
            android:background="@drawable/bg_button"
            android:backgroundTint="@null"
            android:layout_marginBottom="40dp"
            android:layout_gravity="center"
            style="@style/TextAppearance.Kara.Body"/>

        <!-- 2. PROJECTS SECTION -->
        <!-- The Header: Title + Add Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                style="@style/TextAppearance.Kara.Subheader"
                android:text="Your Projects"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />

            <ImageButton
                android:id="@+id/btn_add_project"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_input_add"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Add Project" />
        </LinearLayout>

        <!-- THE ACTUAL CONTAINER: This is where code injects the project items -->
        <LinearLayout
            android:id="@+id/project_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"/>

        <!-- 3. TAGS SECTION -->
        <!-- Header for Tags -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                style="@style/TextAppearance.Kara.Subheader"
                android:text="Common Tags"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content" />

            <ImageButton
                android:id="@+id/btn_add_tag"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_input_add"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Add Tag" />
        </LinearLayout>

        <!-- THE ACTUAL CONTAINER FOR TAGS -->
        <LinearLayout
            android:id="@+id/tag_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>